# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=<minimum-32-char-random-string>
# IMPORTANT: Set to your production domain in production (not localhost)
# e.g. https://house-rent-sale-puce.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Email — using Gmail SMTP via nodemailer
# Use a Gmail App Password (not your account password)
# Generate at: https://myaccount.google.com/apppasswords
# WARNING: Gmail has a 500 emails/day limit.
# For production consider Resend (resend.com) or SendGrid.
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-app-password
# Optional: admin email for account deletion requests (defaults to GMAIL_USER)
ADMIN_EMAIL=admin@yourdomain.com

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# Public env vars for client-side unsigned uploads
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# Map default center (OpenStreetMap/Leaflet — no API key required)
NEXT_PUBLIC_DEFAULT_MAP_LAT=9.03
NEXT_PUBLIC_DEFAULT_MAP_LNG=38.74

# Error Monitoring (optional but recommended for production)
# Get DSN from https://sentry.io after creating a Next.js project
SENTRY_DSN=https://...@sentry.io/...
